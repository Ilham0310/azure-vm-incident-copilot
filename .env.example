# Azure VM Incident Copilot - Environment Configuration
# Copy this file to .env and fill in your values

# Azure Resources
AZURE_SUBSCRIPTION_ID=your_subscription_id_here
AZURE_RESOURCE_GROUP=your_resource_group_here
AZURE_VM_NAME=your_vm_name_here

# LLM Providers (at least one required for Configs B, C, D)
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# RAG Configuration
RAG_TOP_K=5
SOP_TOP_K=3
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Feature Flags
LLM_ENABLED=false
LLM_SHADOW_MODE=false
